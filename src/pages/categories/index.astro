---
import CategoryPreview from "@/components/common/CategoryPreview.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCategoryMap } from "@/utils/post";

const categoryMap = await getCategoryMap();
const categories = categoryMap.keys();
---

<BaseLayout>
  <section
    class="mt-7 grid grid-cols-1 max-md:space-y-4 md:grid-cols-2 md:space-x-4"
  >
    {
      categories.map((category) => (
        <CategoryPreview
          category={category}
          posts={categoryMap.get(category) || []}
        />
      ))
    }
  </section>
</BaseLayout>
