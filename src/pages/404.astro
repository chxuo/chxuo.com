---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Card from "@/components/common/Card.astro";
---

<BaseLayout title="404 - 页面未找到">
  <Card class="mt-16 p-10 text-center">
    <h1 class="mb-4 text-6xl font-bold">404</h1>
    <p class="mb-6 text-xl text-muted-foreground">页面未找到</p>
    <p class="mb-8 text-sm text-muted-foreground">
      抱歉，你访问的页面不存在或已被移除。
    </p>
    <a
      href="/"
      class="inline-block rounded-sm border border-border px-6 py-2 font-medium transition-colors hover:border-primary hover:bg-accent"
    >
      返回首页
    </a>
  </Card>
</BaseLayout>
