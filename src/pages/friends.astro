---
import Container from "@components/Container.astro";
import { FRIENDS } from "@consts";
import Layout from "@layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

const friends = await getCollection("friends")
---

<Layout title={FRIENDS.TITLE} description={FRIENDS.DESCRIPTION}>
  <Container>
    <aside data-pagefind-ignore>
      <div class="space-y-10">
        <div class="animate space-y-4">
          <div class="font-semibold text-black dark:text-white">
            {FRIENDS.TITLE}
          </div>
          <p class="text-gray-600 dark:text-gray-400">
            {FRIENDS.DESCRIPTION}
          </p>
        </div>
        
        <div class="space-y-10">
              <section class="animate space-y-6">

                <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
                  {friends.map(friend => (
                    <a
                      href={friend.data.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="group flex items-center gap-3 p-4 rounded-lg border border-black/10 dark:border-white/10 hover:border-black/20 dark:hover:border-white/20 hover:shadow-md dark:hover:shadow-black/20 transition-all duration-300 bg-white/50 dark:bg-black/20 hover:bg-white/80 dark:hover:bg-black/40"
                    > 
                      <div class="w-12 h-12 flex-shrink-0 overflow-hidden rounded-full">
                        <img 
                          src={friend.data.avatar || `https://api.dicebear.com/7.x/initials/svg?seed=${friend.data.name}`} 
                          alt={`${friend.data.name} avatar`} 
                          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110"
                        />
                      </div>
                      
                      <div class="flex-1 min-w-0">
                        <h3 class="font-medium text-black dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors truncate">
                          {friend.data.name}
                        </h3>
                        {friend.data.description && (
                          <p class="text-gray-600 dark:text-gray-400 text-xs mt-1 line-clamp-2">
                            {friend.data.description}
                          </p>
                        )}
                      </div>
                      
                      <div class="flex-shrink-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-blue-600 dark:text-blue-400">
                          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                          <polyline points="15,3 21,3 21,9"></polyline>
                          <line x1="10" y1="14" x2="21" y2="3"></line>
                        </svg>
                      </div>
                    </a>
                  ))}
                </div>
              </section>
        </div>

        <div class="animate">
          <div class="p-6 rounded-xl border border-dashed border-black/20 dark:border-white/20 space-y-4">
            <div class="text-center">
              <h3 class="font-semibold text-black dark:text-white mb-2">添加友链</h3>
              <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
                欢迎志同道合的朋友交换友链，一起在互联网上分享有趣的内容！
              </p>
            </div>
            
            <div class="space-y-4">
              <div>
                <h4 class="font-medium text-black dark:text-white mb-2">示例</h4>
                <div class="bg-blue-50 dark:bg-blue-900/20 p-4 rounded-lg text-sm">
                  <div class="text-gray-700 dark:text-gray-300 space-y-1">
                    <div><strong>网站名称：</strong>CHXUO</div>
                    <div><strong>网站描述：</strong>业余全栈开发者，希望能在开心快乐每一天的同时，做点有用或者有趣儿的东西</div>
                    <div><strong>网站地址：</strong>https://chxuo.com</div>
                    <div><strong>头像地址：</strong>https://chxuo.com/logo.svg</div>
                  </div>
                </div>
              </div>
              
              <div class="text-center">
                <p class="text-gray-600 dark:text-gray-400 text-sm mb-3">
                  如果你的网站内容积极、更新活跃，可以参考示例格式发送邮件
                </p>
                <a 
                  href="mailto:hi@chxuo.com?subject=友链交换&body=网站名称：%0A网站描述：%0A网站地址：%0A头像地址：" 
                  class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors duration-200 text-sm font-medium"
                >
                  <Icon name="mingcute:mail-line" />
                  邮件联系
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </aside>
  </Container>
</Layout>