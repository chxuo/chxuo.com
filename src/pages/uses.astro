---
import Container from "@components/Container.astro";
import { TOOLS } from "@consts";
import Layout from "@layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const tools = await getCollection("tools")
---

<Layout title={TOOLS.TITLE} description={TOOLS.DESCRIPTION}>
  <Container>
    <aside data-pagefind-ignore>
      <div class="space-y-10">
        <div class="animate space-y-4">
          <div class="font-semibold text-black dark:text-white">
            常用工具
          </div>
          <p class="text-gray-600 dark:text-gray-400">
            我在日常开发和工作中使用的硬件、软件和技术栈
          </p>
        </div>
        
        <div class="space-y-10">
          {
            tools.map((tool) => (
              <section class="animate space-y-4">
                <div class="space-y-2">
                  <h2 class="font-semibold text-black dark:text-white">{tool.data.category}</h2>
                  {tool.data.description && (
                    <p class="text-gray-600 dark:text-gray-400">{tool.data.description}</p>
                  )}
                </div>

                <div class="grid gap-4 md:grid-cols-2">
                  {tool.data.items.map(item => (
                    <a
                      href={item.url}
                      target="_blank"
                      class="group flex gap-3 items-start p-3 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-900/50 transition-colors duration-200"
                    > 
                      <div class="w-12 h-12 flex-shrink-0 flex justify-center items-center">
                        {
                          item.image && (
                            <Image 
                              loading="eager" 
                              width={120} 
                              height={120} 
                              src={item.image} 
                              alt={`${item.name} logo`} 
                              class="rounded-lg"
                            />
                          )   
                        }
                      </div>
                      <div class="flex flex-col gap-1 min-w-0">
                        <h3 class="font-medium text-black dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                          {item.name}
                        </h3>
                        {item.description && (
                          <p class="text-gray-600 dark:text-gray-400 text-sm line-clamp-2">
                            {item.description}
                          </p>
                        )}
                      </div>
                    </a>
                  ))}
                </div>
              </section>
            ))
          }
        </div>
      </div>
    </aside>
  </Container>
</Layout>