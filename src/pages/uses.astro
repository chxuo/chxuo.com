---
import Container from "@components/Container.astro";
import { TOOLS } from "@consts";
import Layout from "@layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const tools = await getCollection("tools")
---

<Layout title={TOOLS.TITLE} description={TOOLS.DESCRIPTION}>
  <Container>
    <aside data-pagefind-ignore>
      <div class="space-y-12">
        <div class="animate space-y-3">
            <h1 class="heading text-2xl font-semibold">常用工具</h1>
            <p class="text-gray-600 dark:text-gray-400">
                我在日常开发和工作中使用的硬件、软件和技术栈
            </p>
        </div>
        <div class="animate not-prose flex flex-col gap-12">
          {
            tools.map((tool) => (
                <section class="space-y-6">
                    <div class="space-y-2">
                        <h2 class="heading text-xl">{tool.data.category}</h2>
                        <p class="text-gray-600 dark:text-gray-400 bg-base">{tool.data.description}</p>
                    </div>

                    <div class="grid gap-6 md:grid-cols-2">
                        {tool.data.items.map(item => (
                        <a
                            href={item.url}
                            target="_blank"
                            class="transform hover:-translate-y-1 flex gap-3 items-center transition-all transition-200"
                        > 
                            <div class="w-15 h-15 flex justify-center items-center">
                            {
                                item.image && (
                                    <Image loading="eager" width={120} src={item.image} alt={`${item.name}'s image'`} />
                                )   
                            }
                            </div>
                            <div class="flex flex-col group gap-1">
                            <h3 class="heading color-base hover:text-primary-500 text-lg">{item.name}</h3>
                            <p class="text-gray-600 dark:text-gray-400 switch-animation text-sm">{item.description}</p>
                            </div>
                        </a>
                        ))}
                    </div>
                </section>
            ))
          }
        </div>
      </div>
    </aside>
    </aside>
  </Container>
</Layout>