---
import Umami from "@/components/analytics/Umami.astro";
import ThemeManager from "@/components/blocks/ThemeManager.astro";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import BaseHead from "@/components/meta/BaseHead.astro";
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  author?: string;
}

const head = Astro.props;
---

<html lang="zh-CN">
  <head>
    <BaseHead {...head} />
    <ClientRouter />
    <ThemeManager defaultTheme="auto" />
  </head>
  <body
    class="mx-auto max-w-2xl bg-background px-4 pt-6 pb-8 font-sans text-foreground md:pt-12 lg:px-8 lg:pt-16"
  >
    <Header />
    <main class="fade-in">
      <slot />
    </main>
    <Footer />

    <Umami />
  </body>
</html>
