---
import { Icon } from "astro-icon/components";
---

<button
  id="theme-toggle"
  type="button"
  aria-label="切换主题"
  class="inline-flex items-center justify-center rounded-sm p-2 text-foreground transition-colors hover:bg-accent"
>
  <Icon size={20} name="tabler:sun" class="dark:hidden" />
  <Icon size={20} name="tabler:moon" class="hidden dark:block" />
</button>

<script>
  document.addEventListener("astro:page-load", () => {
    const themeToggle = document.getElementById("theme-toggle");
    if (themeToggle) {
      themeToggle.onclick = () => {
        const doc = document.documentElement;
        doc.classList.add("no-transition");
        doc.classList.toggle("dark");
        const isDark = doc.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
        setTimeout(() => doc.classList.remove("no-transition"), 0);
      };
    }
  });
</script>
