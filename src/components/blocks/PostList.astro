---
import PostPreview from "../common/PostPreview.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"posts">[];
}

const { posts } = Astro.props;
---

<section
  class="mt-7 grid grid-cols-1 max-md:space-y-4 md:grid-cols-2 md:space-x-4"
>
  {posts.map((post) => <PostPreview post={post} />)}
</section>
