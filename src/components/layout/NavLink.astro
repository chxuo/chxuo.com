---
import type { NavLinkType } from "@/types";

interface Props {
  link: NavLinkType;
  active: boolean;
}

const { link, active } = Astro.props;
---

<a
  href={link.href}
  aria-label={link.label}
  title={link.label}
  class:list={[
    "relative px-2 py-1 text-sm font-medium transition-colors",
    active ? "text-primary" : "text-muted-foreground hover:text-foreground",
  ]}
>
  {link.label}
  {active && <span class="absolute right-0 bottom-0 left-0 h-0.5 bg-primary" />}
</a>
