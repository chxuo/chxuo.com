---
import { SITE } from "@consts";

const domain = SITE.PLAUSIBLE_DOMAIN;
// 优先使用环境变量，然后是配置文件，最后是默认值
const apiHost = import.meta.env.PLAUSIBLE_API_HOST || SITE.PLAUSIBLE_API_HOST;

// 只有配置了域名才加载脚本
const shouldLoad = (domain && domain.length > 0) && apiHost;
---

{shouldLoad && (
  <script 
    defer 
    data-domain={domain}
    src={`${apiHost}/js/script.js`}
  ></script>
)}