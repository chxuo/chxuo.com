---
import { Icon } from 'astro-icon/components';

interface Props {
  date: Date;
}

const { date } = Astro.props;
---

<time datetime={date.toISOString()} class="flex items-center gap-1">
  <Icon name="mingcute:time-line" />
  {
    date.toLocaleDateString("zh-CN", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  }
</time>
