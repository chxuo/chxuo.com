---
import { getTag } from "@/utils/post";
import { Icon } from "astro-icon/components";

interface Props {
  tag: string;
  cnt: number;
}

const { tag: tagName, cnt: postCnt } = Astro.props;

const tag = await getTag(tagName);
---

{
  tag && (
    <a
      href={`/tags/${tag.data.slug}`}
      class="group inline-flex items-center gap-2 rounded-sm border border-border bg-card px-3 py-2 transition-colors hover:border-primary hover:bg-accent"
    >
      <Icon name="tabler:hash" class="h-4 w-4 text-muted-foreground" />
      <span class="text-sm font-medium">{tag.data.name}</span>
      <span class="ml-auto rounded-sm bg-muted px-2 py-0.5 text-xs font-medium text-muted-foreground">
        {postCnt}
      </span>
    </a>
  )
}
