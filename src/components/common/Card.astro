---
interface Props {
  href?: string;
  title?: string;
  class?: string;
}

const { href, title, class: className } = Astro.props;

const Element = href ? "a" : "div";
const extraProps = href ? { href, title } : {};
---

<Element
  class:list={[
    "rounded-sm opacity-75 hover:bg-muted hover:opacity-100",
    className,
  ]}
  {...extraProps}
>
  <slot />
</Element>
