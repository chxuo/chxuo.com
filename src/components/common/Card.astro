---
interface Props {
  href?: string;
  title?: string;
  class?: string;
}

const { href, title, class: className } = Astro.props;

const Element = href ? "a" : "div";
const extraProps = href ? { href, title } : {};
---

<Element
  class:list={["rounded-sm border border-border", className]}
  {...extraProps}
>
  <slot />
</Element>
