---
interface Props {
  href?: string;
  title?: string;
  class?: string;
}

const { href, title, class: className } = Astro.props;

const Element = href ? "a" : "div";
const extraProps = href ? { href, title } : {};
---

<Element
  class:list={[
    "rounded-sm border border-border transition-colors",
    href && "hover:border-primary hover:bg-accent",
    className,
  ]}
  {...extraProps}
>
  <slot />
</Element>
